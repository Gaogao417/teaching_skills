<# exam-zh-explanation.tex.j2 — 讲解页模板
   设计目标：
   1. 题目区是入口，长蓝线 + 大题干；
   2. 思路导航用 SubQuestionItem 风格；
   3. 只有主体讲解使用双栏；
   4. 变式训练使用完整题目 + 留白；
   5. 答案和方法提醒做轻量收束。
#>
<% include "preamble-exam-zh-v2.tex" ignore missing %>

\examsetup{
  question/show-answer = true,
  fillin/show-answer = true,
  solution/show-solution = show-stay,
}

\begin{document}

<% for section in sections %>
<% if section.visibility != "teacher" or meta.version != "student" %>
<% if (section.layout and section.layout.break_before) or section.type == "answer_key" or section.visibility == "teacher" %>
\clearpage
<% endif %>
<% if section.title and section.show_title %>
\eduSectionTitle{<%= section.title|latex_escape %>}
<% endif %>
<% for block in section.blocks %>

<# ———————————————————————————
   原题卡片：页面入口
   支持字段：block.label / block.stem / block.stem_latex / block.subquestions
——————————————————————————— #>
<% if block.type == "problemcard" or block.type == "problem" or block.type == "short_answer" %>
\begin{eduProblemBlock}[<% if block.label %><%= block.label|latex_escape %><% else %>题目<% endif %>]
<% set diagram_col = block.diagram_col or block.prompt_diagram %>
<% if diagram_col %>
\noindent
\begin{minipage}[t]{0.64\linewidth}
\vspace{0pt}
<% if block.stem_latex %>
<%= block.stem_latex %>
<% else %>
<%= block.stem|latex_escape %>
<% endif %>
<% if block.subquestions %>
\begin{eduSubQuestions}
<% for item in block.subquestions %>
  \item <% if item.latex %><%= item.latex %><% elif item.text %><%= item.text|latex_escape %><% else %><%= item|latex_escape %><% endif %>
<% endfor %>
\end{eduSubQuestions}
<% endif %>
\end{minipage}\hfill
\diagramcolfigure{<%= diagram_col.image_path|latex_path %>}{<%= diagram_col.width|default("0.30\\linewidth") %>}{<% if diagram_col.caption %><%= diagram_col.caption|latex_escape %><% endif %>}
<% else %>
<% if block.stem_latex %>
<%= block.stem_latex %>
<% else %>
<%= block.stem|latex_escape %>
<% endif %>
<% if block.subquestions %>
\begin{eduSubQuestions}
<% for item in block.subquestions %>
  \item <% if item.latex %><%= item.latex %><% elif item.text %><%= item.text|latex_escape %><% else %><%= item|latex_escape %><% endif %>
<% endfor %>
\end{eduSubQuestions}
<% endif %>
<% endif %>
<% if block.answer_space and meta.version == "student" %>
\answerarea[<%= block.answer_space.height|default("35mm") %>]
<% endif %>
\end{eduProblemBlock}

<% if meta.version != "student" and block.explanation %>
\begin{eduLegacySolution}
<% if block.explanation_latex %><%= block.explanation_latex %><% else %><%= block.explanation|latex_escape %><% endif %>
\end{eduLegacySolution}
<% endif %>

<# ———————————————————————————
   思路导航：辅助信息条（楷体 + 图标）
   支持字段：block.steps
——————————————————————————— #>
<% elif block.type == "route" %>
\begin{eduAuxItem}{思路导航}
<% for step in block.steps|default([]) %>
<% if step.latex %><%= step.latex %><% elif step.text %><%= step.text|latex_escape %><% else %><%= step|latex_escape %><% endif %><% if not loop.last %>$\;\to\;$<% endif %>
<% endfor %>
\end{eduAuxItem}

<# ———————————————————————————
   读题提示：跳过，不渲染
——————————————————————————— #>
<% elif block.type == "reading_tip" %>

<# ———————————————————————————
   兼容普通 solution block：单栏解答盒子
——————————————————————————— #>
<% elif block.type == "solution" %>
<% if block.stem_latex or block.stem %>
\begin{eduSubQuestionItem}{<% if block.label %><%= block.label|latex_escape %><% else %>(\arabic*)<% endif %>}
<% if block.stem_latex %><%= block.stem_latex %><% else %><%= block.stem|latex_escape %><% endif %>
\end{eduSubQuestionItem}
<% endif %>

\begin{eduSolutionBox}{<% if block.title %><%= block.title|latex_escape %><% else %>解答<% endif %>}
  \begingroup
  \setlength{\parskip}{2.5mm}
  <% for item in block.get('items', []) %>
    <% if item.latex %><%= item.latex %><% elif item.text %><%= item.text|latex_escape %><% elif item.content_latex %><%= item.content_latex %><% elif item.content %><%= item.content|latex_escape %><% else %><%= item|latex_escape %><% endif %>\par
  <% endfor %>
  \endgroup
\end{eduSolutionBox}

<# ———————————————————————————
   主体讲解：小问级双栏
   左栏：hint / mistake / note
   右栏：step1. 标题 + 正文
——————————————————————————— #>
<% elif block.type == "explanation_dual" or block.type == "dual_explanation" %>
<% if block.stem_latex or block.stem %>
\begin{eduSubQuestionItem}{<% if block.label %><%= block.label|latex_escape %><% else %>(\arabic*)<% endif %>}
<% if block.stem_latex %><%= block.stem_latex %><% else %><%= block.stem|latex_escape %><% endif %>
\end{eduSubQuestionItem}
<% endif %>

\begin{eduDualExplain}
  \begin{eduExplainLeft}
    \eduColumnTitle{\eduIconBulb}{<% if block.side_title %><%= block.side_title|latex_escape %><% else %>提示与易错<% endif %>}
    <% for item in block.side_items|default([]) %>
      <% if item.kind == "hint" %>
        \eduSideHint{<%= item.title|latex_escape %>}{<% if item.content_latex %><%= item.content_latex %><% elif item.latex %><%= item.latex %><% else %><%= item.content|latex_escape %><% endif %>}
      <% elif item.kind == "mistake" %>
        \eduSideMistake{<%= item.title|latex_escape %>}{<% if item.content_latex %><%= item.content_latex %><% elif item.latex %><%= item.latex %><% else %><%= item.content|latex_escape %><% endif %>}
      <% else %>
        \eduSideNote{<%= item.title|latex_escape %>}{<% if item.content_latex %><%= item.content_latex %><% elif item.latex %><%= item.latex %><% else %><%= item.content|latex_escape %><% endif %>}
      <% endif %>
    <% endfor %>
  \end{eduExplainLeft}

  \begin{eduExplainRight}
    \eduColumnTitle{\eduIconBook}{<% if block.solution_title %><%= block.solution_title|latex_escape %><% else %>解答<% endif %>}
    <% for step in block.solution_steps|default([]) %>
      \eduExplainStep{<%= loop.index %>}{<% if step.latex %><%= step.latex %><% elif step.text %><%= step.text|latex_escape %><% else %><%= step.title|latex_escape %><% endif %>}{<% if step.content_latex %><%= step.content_latex %><% else %><%= step.content|latex_escape %><% endif %>}
    <% endfor %>
  <% if block.connection_items %>
    \vspace{1mm}
    {\color{edu-blue}\bfseries\small <% if block.connection_title %><%= block.connection_title|latex_escape %><% else %>注意<% endif %>}\par\vspace{1mm}
    \begin{eduBulletList}
    <% for item in block.connection_items %>
      \item <% if item.content_latex %><%= item.content_latex %><% elif item.latex %><%= item.latex %><% elif item.text %><%= item.text|latex_escape %><% elif item.content %><%= item.content|latex_escape %><% else %><%= item|latex_escape %><% endif %>
    <% endfor %>
    \end{eduBulletList}
  <% endif %>
  \end{eduExplainRight}
\end{eduDualExplain}

<# ———————————————————————————
   答案 + 方法提醒：双栏收束
——————————————————————————— #>
<% elif block.type == "summary_dual" or block.type == "answer_reminder" %>
\begin{eduBottomGrid}
  \begin{eduSummaryLeft}
    \begin{eduSummaryBlock}{\eduIconCheck}{<% if block.left_title %><%= block.left_title|latex_escape %><% else %>答案<% endif %>}
    \begin{eduPlainList}
    <% for item in block.left_items|default([]) %>
      \item <% if item.latex %><%= item.latex %><% elif item.text %><%= item.text|latex_escape %><% else %><%= item|latex_escape %><% endif %>
    <% endfor %>
    \end{eduPlainList}
    \end{eduSummaryBlock}
  \end{eduSummaryLeft}
  \eduSummaryDivider
  \begin{eduSummaryRight}
    \begin{eduSummaryBlock}{\eduIconPin}{<% if block.right_title %><%= block.right_title|latex_escape %><% else %>方法提醒<% endif %>}
    \begin{eduBulletList}
    <% for item in block.right_items|default([]) %>
      \item <% if item.latex %><%= item.latex %><% elif item.text %><%= item.text|latex_escape %><% elif item.content %><%= item.content|latex_escape %><% else %><%= item|latex_escape %><% endif %>
    <% endfor %>
    \end{eduBulletList}
    \end{eduSummaryBlock}
  \end{eduSummaryRight}
\end{eduBottomGrid}

<# ———————————————————————————
   答案区：轻量总结
——————————————————————————— #>
<% elif block.type == "answer" or block.type == "answers" %>
\begin{eduSummaryBlock}{\eduIconCheck}{<% if block.title %><%= block.title|latex_escape %><% else %>答案<% endif %>}
<% if block.get('items') %>
\begin{eduPlainList}
<% for item in block.get('items') %>
  \item <% if item.latex %><%= item.latex %><% elif item.text %><%= item.text|latex_escape %><% else %><%= item|latex_escape %><% endif %>
<% endfor %>
\end{eduPlainList}
<% elif block.content_latex %>
<%= block.content_latex %>
<% else %>
<%= block.content|latex_escape %>
<% endif %>
\end{eduSummaryBlock}

<# ———————————————————————————
   方法提醒
——————————————————————————— #>
<% elif block.type == "method_reminder" or block.type == "reminder" %>
\begin{eduSummaryBlock}{\eduIconPin}{<% if block.title %><%= block.title|latex_escape %><% else %>方法提醒<% endif %>}
\begin{eduBulletList}
<% for item in block.get('items', []) %>
  \item <% if item.latex %><%= item.latex %><% elif item.text %><%= item.text|latex_escape %><% elif item.content %><%= item.content|latex_escape %><% else %><%= item|latex_escape %><% endif %>
<% endfor %>
\end{eduBulletList}
\end{eduSummaryBlock}

<# ———————————————————————————
   兼容旧 block
——————————————————————————— #>
<% elif block.type == "step" %>
\begin{eduSoftBox}
  <% if block.title %>\eduSubTitle{<%= block.title|latex_escape %>}<% endif %>
  <% if block.content_latex %><%= block.content_latex %><% else %><%= block.content|latex_escape %><% endif %>
  <% if block.why %>\par{\small\color{edu-muted}<%= block.why|latex_escape %>}<% endif %>
  <% for sub in block.substeps|default([]) %>
    \par\hspace{5mm}{\small — <%= sub|latex_escape %>}
  <% endfor %>
\end{eduSoftBox}

<% elif block.type == "mistake" %>
\begin{eduMistakeBox}
  <% if block.title %>\eduSubTitle{<%= block.title|latex_escape %>}<% endif %>
  <% if block.content_latex %><%= block.content_latex %><% else %><%= block.content|latex_escape %><% endif %>
\end{eduMistakeBox}

<% elif block.type == "hint" %>
\begin{eduAuxItem}{提示}
<% if block.content_latex %><%= block.content_latex %><% else %><%= block.content|latex_escape %><% endif %>
\end{eduAuxItem}

<% elif block.type == "variation_training" %>
\begin{eduVariationTraining}{<% if block.label %><%= block.label|latex_escape %><% elif block.title %><%= block.title|latex_escape %><% else %>变式训练<% endif %>}
<% if block.stem_latex %>
<%= block.stem_latex %>
<% else %>
<%= block.stem|latex_escape %>
<% endif %>
<% if block.subquestions %>
\begin{eduSubQuestions}
<% for item in block.subquestions %>
  \item <% if item.latex %><%= item.latex %><% elif item.text %><%= item.text|latex_escape %><% else %><%= item|latex_escape %><% endif %>
<% endfor %>
\end{eduSubQuestions}
<% endif %>
\answerarea[<%= block.answer_space.height|default("36mm") %>]
\end{eduVariationTraining}

<% elif block.type == "diagram" %>
\needspace{10\baselineskip}
\begin{center}
  \includegraphics[width=<% if block.width %><%= block.width %><% else %>0.82\linewidth<% endif %>]{\detokenize{<%= block.image_path|latex_path %>}}
  <% if block.caption %>
  \par\vspace{1mm}{\small\color{edu-muted}<%= block.caption|latex_escape %>}
  <% endif %>
\end{center}

<% elif block.type == "choice" %>
\begin{question}[points=<%= block.points|default(4) %>]
  <% if block.stem_latex %><%= block.stem_latex %><% else %><%= block.stem|latex_escape %><% endif %>
  \begin{choices}
  <% for key, text in block.choices|dictsort %>
    \item <%= text|latex_escape %>
  <% endfor %>
  \end{choices}
  <% if meta.version != "student" and block.answer %>
  \paren[<%= block.answer|latex_escape %>]
  <% endif %>
\end{question}

<% elif block.type == "fillin" %>
\begin{question}[points=<%= block.points|default(4) %>]
  <% if block.stem_latex %><%= block.stem_latex %><% else %><%= block.stem|latex_escape %><% endif %>
  <% if meta.version != "student" and block.answer %>
  \paren[<%= block.answer|latex_escape %>]
  <% endif %>
\end{question}

<% endif %>

<% if meta.version != "student" and block.teaching %>
\begin{eduTeacherNote}
  <% if block.teaching.teaching_goal %>
  \textbf{训练目标：}<%= block.teaching.teaching_goal|latex_escape %>\par
  <% endif %>
  <% if block.teaching.expected_blocker %>
  \textbf{预期卡点：}<%= block.teaching.expected_blocker|latex_escape %>
  <% endif %>
\end{eduTeacherNote}
<% endif %>

<% endfor %><# blocks #>
<% endif %>
<% endfor %><# sections #>

\end{document}
