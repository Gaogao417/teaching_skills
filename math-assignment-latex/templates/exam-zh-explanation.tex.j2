<# exam-zh-explanation.tex.j2 — 讲解页模板
   设计目标：
   1. 题目区是入口，长蓝线 + 大题干；
   2. 解题流程用 SubQuestionItem 风格；
   3. 关键想法用纯文本；
   4. 只有主体讲解使用双栏；
   5. 答案和方法提醒做轻量收束。
#>
<% include "preamble-exam-zh-v2.tex" ignore missing %>

<% if meta.version == "student" %>
\examsetup{
  question/show-answer = false,
  fillin/show-answer = false,
  solution/show-solution = hide,
}
<% elif meta.version == "teacher" %>
\examsetup{
  question/show-answer = true,
  fillin/show-answer = true,
  solution/show-solution = show-stay,
}
<% endif %>

\begin{document}

<% for section in sections %>
<# 教师专属区块或答案页：自动另起一页（不依赖 YAML layout 字段）#>
<% if section.type == "answer_key" or section.visibility == "teacher" %>
\clearpage
<% endif %>
<% if section.title and section.show_title %>
\eduSectionTitle{<%= section.title|latex_escape %>}
<% endif %>
<% for block in section.blocks %>

<# ———————————————————————————
   原题卡片：页面入口
   支持字段：block.label / block.stem / block.stem_latex / block.subquestions
——————————————————————————— #>
<% if block.type == "problemcard" or block.type == "problem" or block.type == "short_answer" %>
\begin{eduProblemBlock}[<% if block.label %><%= block.label|latex_escape %><% else %>题目<% endif %>]
<% if block.stem_latex %>
<%= block.stem_latex %>
<% else %>
<%= block.stem|latex_escape %>
<% endif %>
<% if block.subquestions %>
\begin{eduSubQuestions}
<% for item in block.subquestions %>
  \item <% if item.latex %><%= item.latex %><% elif item.text %><%= item.text|latex_escape %><% else %><%= item|latex_escape %><% endif %>
<% endfor %>
\end{eduSubQuestions}
<% endif %>
<% if block.answer_space and meta.version == "student" %>
\answerarea[<%= block.answer_space.height|default("35mm") %>]
<% endif %>
\end{eduProblemBlock}

<% if meta.version != "student" and block.explanation %>
\begin{eduLegacySolution}
<% if block.explanation_latex %><%= block.explanation_latex %><% else %><%= block.explanation|latex_escape %><% endif %>
\end{eduLegacySolution}
<% endif %>

<# ———————————————————————————
   解题流程：辅助信息条（楷体 + 图标）
   支持字段：block.steps
——————————————————————————— #>
<% elif block.type == "route" %>
\begin{eduAuxItem}{解题流程}
<% for step in block.steps|default([]) %>
<% if step.latex %><%= step.latex %><% elif step.text %><%= step.text|latex_escape %><% else %><%= step|latex_escape %><% endif %><% if not loop.last %>$\;\to\;$<% endif %>
<% endfor %>
\end{eduAuxItem}

<# ———————————————————————————
   关键想法：辅助信息条（楷体 + 图标）
   支持字段：block.content
——————————————————————————— #>
<% elif block.type == "key_idea" %>
\begin{eduAuxItem}{关键想法}
<% if block.content_latex %><%= block.content_latex %><% else %><%= block.content|latex_escape %><% endif %>
\end{eduAuxItem}

<# ———————————————————————————
   读题提示：跳过，不渲染
——————————————————————————— #>
<% elif block.type == "reading_tip" %>

<# ———————————————————————————
   主体讲解：唯一使用双栏的区域
   小问题干 + 双栏讲解视作整体，不允许中间分页
   支持字段：
   block.label / block.stem_latex / block.stem
   block.left_title / block.left_items
   block.right_title / block.right_steps
   block.connection_title / block.connection_items
——————————————————————————— #>
<% elif block.type == "explanation_dual" or block.type == "dual_explanation" %>
<% if block.stem_latex or block.stem %>
\begin{eduSubQuestionItem}{<% if block.label %><%= block.label|latex_escape %><% else %>(\arabic*)<% endif %>}
<% if block.stem_latex %><%= block.stem_latex %><% else %><%= block.stem|latex_escape %><% endif %>
\end{eduSubQuestionItem}
<% endif %>

\begin{eduDualExplain}
  \begin{eduExplainLeft}
    \eduColumnTitle{\eduIconBook}{<% if block.left_title %><%= block.left_title|latex_escape %><% else %>解答<% endif %>}
    \begin{eduNumberList}
    <% for item in block.left_items|default([]) %>
      \item <% if item.latex %><%= item.latex %><% elif item.text %><%= item.text|latex_escape %><% elif item.content %><%= item.content|latex_escape %><% else %><%= item|latex_escape %><% endif %>
    <% endfor %>
    \end{eduNumberList}
  \end{eduExplainLeft}
  \eduColumnDivider
  \begin{eduExplainRight}
    \eduColumnTitle{\eduIconNote}{<% if block.right_title %><%= block.right_title|latex_escape %><% else %>例题重做<% endif %>}
    \begin{eduNumberList}
    <% for step in block.right_steps|default([]) %>
      \item <% if step.latex %><%= step.latex %><% elif step.text %><%= step.text|latex_escape %><% elif step.content %><%= step.content|latex_escape %><% else %><%= step|latex_escape %><% endif %>
    <% endfor %>
    \end{eduNumberList}

    <% if block.connection_items %>
    \vspace{1mm}
    \eduSubTitle{<% if block.connection_title %><%= block.connection_title|latex_escape %><% else %>后两问如何承接<% endif %>}
    \begin{eduBulletList}
    <% for item in block.connection_items %>
      \item <% if item.latex %><%= item.latex %><% elif item.text %><%= item.text|latex_escape %><% elif item.content %><%= item.content|latex_escape %><% else %><%= item|latex_escape %><% endif %>
    <% endfor %>
    \end{eduBulletList}
    <% endif %>
  \end{eduExplainRight}
\end{eduDualExplain}

<# ———————————————————————————
   答案 + 方法提醒：双栏收束
——————————————————————————— #>
<% elif block.type == "summary_dual" or block.type == "answer_reminder" %>
\begin{eduBottomGrid}
  \begin{eduSummaryLeft}
    \begin{eduSummaryBlock}{\eduIconCheck}{<% if block.left_title %><%= block.left_title|latex_escape %><% else %>答案<% endif %>}
    \begin{eduPlainList}
    <% for item in block.left_items|default([]) %>
      \item <% if item.latex %><%= item.latex %><% elif item.text %><%= item.text|latex_escape %><% else %><%= item|latex_escape %><% endif %>
    <% endfor %>
    \end{eduPlainList}
    \end{eduSummaryBlock}
  \end{eduSummaryLeft}
  \eduSummaryDivider
  \begin{eduSummaryRight}
    \begin{eduSummaryBlock}{\eduIconPin}{<% if block.right_title %><%= block.right_title|latex_escape %><% else %>方法提醒<% endif %>}
    \begin{eduBulletList}
    <% for item in block.right_items|default([]) %>
      \item <% if item.latex %><%= item.latex %><% elif item.text %><%= item.text|latex_escape %><% elif item.content %><%= item.content|latex_escape %><% else %><%= item|latex_escape %><% endif %>
    <% endfor %>
    \end{eduBulletList}
    \end{eduSummaryBlock}
  \end{eduSummaryRight}
\end{eduBottomGrid}

<# ———————————————————————————
   答案区：轻量总结
——————————————————————————— #>
<% elif block.type == "answer" or block.type == "answers" %>
\begin{eduSummaryBlock}{\eduIconCheck}{<% if block.title %><%= block.title|latex_escape %><% else %>答案<% endif %>}
<% if block.get('items') %>
\begin{eduPlainList}
<% for item in block.get('items') %>
  \item <% if item.latex %><%= item.latex %><% elif item.text %><%= item.text|latex_escape %><% else %><%= item|latex_escape %><% endif %>
<% endfor %>
\end{eduPlainList}
<% elif block.content_latex %>
<%= block.content_latex %>
<% else %>
<%= block.content|latex_escape %>
<% endif %>
\end{eduSummaryBlock}

<# ———————————————————————————
   方法提醒
——————————————————————————— #>
<% elif block.type == "method_reminder" or block.type == "reminder" %>
\begin{eduSummaryBlock}{\eduIconPin}{<% if block.title %><%= block.title|latex_escape %><% else %>方法提醒<% endif %>}
\begin{eduBulletList}
<% for item in block.get('items', []) %>
  \item <% if item.latex %><%= item.latex %><% elif item.text %><%= item.text|latex_escape %><% elif item.content %><%= item.content|latex_escape %><% else %><%= item|latex_escape %><% endif %>
<% endfor %>
\end{eduBulletList}
\end{eduSummaryBlock}

<# ———————————————————————————
   兼容旧 block
——————————————————————————— #>
<% elif block.type == "step" %>
\begin{eduSoftBox}
  <% if block.title %>\eduSubTitle{<%= block.title|latex_escape %>}<% endif %>
  <% if block.content_latex %><%= block.content_latex %><% else %><%= block.content|latex_escape %><% endif %>
  <% if block.why %>\par{\small\color{edu-muted}<%= block.why|latex_escape %>}<% endif %>
  <% for sub in block.substeps|default([]) %>
    \par\hspace{5mm}{\small — <%= sub|latex_escape %>}
  <% endfor %>
\end{eduSoftBox}

<% elif block.type == "mistake" %>
\begin{eduMistakeBox}
  <% if block.title %>\eduSubTitle{<%= block.title|latex_escape %>}<% endif %>
  <% if block.content_latex %><%= block.content_latex %><% else %><%= block.content|latex_escape %><% endif %>
\end{eduMistakeBox}

<% elif block.type == "hint" %>
\begin{eduAuxItem}{思考}
<% if block.content_latex %><%= block.content_latex %><% else %><%= block.content|latex_escape %><% endif %>
\end{eduAuxItem}

<% elif block.type == "choice" %>
\begin{question}[points=<%= block.points|default(4) %>]
  <% if block.stem_latex %><%= block.stem_latex %><% else %><%= block.stem|latex_escape %><% endif %>
  \begin{choices}
  <% for key, text in block.choices|dictsort %>
    \item <%= text|latex_escape %>
  <% endfor %>
  \end{choices}
  <% if meta.version != "student" and block.answer %>
  \paren[<%= block.answer|latex_escape %>]
  <% endif %>
\end{question}

<% elif block.type == "fillin" %>
\begin{question}[points=<%= block.points|default(4) %>]
  <% if block.stem_latex %><%= block.stem_latex %><% else %><%= block.stem|latex_escape %><% endif %>
  <% if meta.version != "student" and block.answer %>
  \fillin[<%= block.answer|latex_escape %>]
  <% else %>
  \fillin
  <% endif %>
\end{question}

<% endif %>

<% if meta.version != "student" and block.teaching %>
\begin{eduTeacherNote}
  <% if block.teaching.teaching_goal %>
  \textbf{训练目标：}<%= block.teaching.teaching_goal|latex_escape %>\par
  <% endif %>
  <% if block.teaching.expected_blocker %>
  \textbf{预期卡点：}<%= block.teaching.expected_blocker|latex_escape %>
  <% endif %>
\end{eduTeacherNote}
<% endif %>

<% endfor %><# blocks #>
<% endfor %><# sections #>

\end{document}
