<# exam-zh-homework.tex.j2 — 作业页模板 #>
<% include "preamble-exam-zh.tex" ignore missing %>

<% if meta.version == "student" %>
\examsetup{
  question/show-answer = false,
  fillin/show-answer = false,
  solution/show-solution = hide,
}
<% elif meta.version == "teacher" %>
\examsetup{
  question/show-answer = true,
  fillin/show-answer = true,
  solution/show-solution = show-stay,
}
<% endif %>

\begin{document}

<% if meta.title %>
\title{<%= meta.title|latex_escape %>}
<% endif %>
<% if meta.subtitle or meta.grade %>
\subject{<%= meta.subtitle|default("")|latex_escape %><% if meta.grade %> · <%= meta.grade|latex_escape %><% endif %><% if meta.duration %>（<%= meta.duration|latex_escape %>）<% endif %>}
<% endif %>
\maketitle

<% for section in sections %>
<# 答案页：自动另起一页（不依赖 YAML layout 字段）#>
<% if section.type == "answer_key" %>
\clearpage
<% endif %>
<% if section.title %>
\section*{<%= section.title|latex_escape %>}
<% endif %>

<% for block in section.blocks %>
<# 解答题：模板层自动保护标题与答题区不被截断 #>
<% if block.type in ("problem", "short_answer") %>
\needspace{8\baselineskip}
<% endif %>

<% if block.type == "problemcard" %>
\begin{problemcard}
  <% if block.title %>\textbf{<%= block.title|latex_escape %>}\par<% endif %>
  <%= block.stem|latex_escape %>
\end{problemcard}

<% elif block.type == "choice" %>
<% set diagram_col = block.diagram_col or block.prompt_diagram %>
<% if diagram_col %>
<% set diagram_width = diagram_col.width|default("60mm") %>
\needspace{14\baselineskip}
\begin{question}[points=<%= block.points|default(4) %>]
  \noindent
  \begin{minipage}[t]{\dimexpr\linewidth-<%= diagram_width %>-6mm\relax}
    \vspace{0pt}
    <% if block.stem_latex %><%= block.stem_latex %><% else %><%= block.stem|latex_escape %><% endif %>
    \par
    \begin{choices}[columns=1]
    <% for key, text in block.choices|dictsort %>
      \item <%= text|latex_escape %>
    <% endfor %>
    \end{choices}
  \end{minipage}\hfill
  \diagramcolfigure{<%= diagram_col.image_path|latex_path %>}{<%= diagram_width %>}{<% if diagram_col.caption %><%= diagram_col.caption|latex_escape %><% endif %>}
  <% if meta.version != "student" and block.answer %>
  \paren[<%= block.answer|latex_escape %>]
  <% endif %>
\end{question}

<% else %>
\begin{question}[points=<%= block.points|default(4) %>]
  <% if block.stem_latex %><%= block.stem_latex %><% else %><%= block.stem|latex_escape %><% endif %>
  \begin{choices}
  <% for key, text in block.choices|dictsort %>
    \item <%= text|latex_escape %>
  <% endfor %>
  \end{choices}
  <% if meta.version != "student" and block.answer %>
  \paren[<%= block.answer|latex_escape %>]
  <% endif %>
\end{question}
<% endif %>

<% elif block.type == "fillin" %>
\begin{question}[points=<%= block.points|default(4) %>]
  <% if block.stem_latex %><%= block.stem_latex %><% else %><%= block.stem|latex_escape %><% endif %>
  <% if meta.version != "student" and block.answer %>
  \paren[<%= block.answer|latex_escape %>]
  <% endif %>
\end{question}

<% elif block.type == "diagram_row" %>
<% set diagram_items = block.get("items") or block.get("diagrams") %>
\needspace{<%= block.needspace|default("18\\baselineskip") %>}
\begin{center}
  <% for item in diagram_items|default([]) %>
  \diagramrowitem{<%= item.image_path|latex_path %>}{<%= item.width|default("0.22\\linewidth") %>}{<% if item.label %><%= item.label|latex_escape %><% endif %>}{<% if item.caption %><%= item.caption|latex_escape %><% endif %>}<% if not loop.last %>\hfill<% endif %>
  <% endfor %>
\end{center}

<% elif block.type == "problem" or block.type == "short_answer" %>
\begin{problem}[points=<%= block.points|default(8) %>]
  <% if block.stem_latex %><%= block.stem_latex %><% else %><%= block.stem|latex_escape %><% endif %>
  <% if block.answer_space %>
  <% set default_diagram_col = block.answer_space.diagram_col or block.answer_space.diagram or block.diagram_col or block.prompt_diagram %>
  <% if block.answer_space.parts %>
    <% for part in block.answer_space.parts %>
      <% set part_diagram_col = part.diagram_col or part.prompt_diagram or part.diagram or default_diagram_col %>
      <% if part.label %>
  \noindent\textbf{<%= part.label|latex_escape %>}\par
      <% endif %>
      <% if part_diagram_col %>
  \answerareawithdiagramcol{<%= part.height|default(block.answer_space.height|default("35mm")) %>}{<%= part_diagram_col.image_path|latex_path %>}{<%= part_diagram_col.width|default("60mm") %>}{<% if part_diagram_col.caption %><%= part_diagram_col.caption|latex_escape %><% endif %>}
      <% else %>
  \answerarea[<%= part.height|default(block.answer_space.height|default("35mm")) %>]
      <% endif %>
    <% endfor %>
  <% elif default_diagram_col %>
  \answerareawithdiagramcol{<%= block.answer_space.height|default("35mm") %>}{<%= default_diagram_col.image_path|latex_path %>}{<%= default_diagram_col.width|default("60mm") %>}{<% if default_diagram_col.caption %><%= default_diagram_col.caption|latex_escape %><% endif %>}
  <% else %>
  \answerarea[<%= block.answer_space.height|default("35mm") %>]
  <% endif %>
  <% endif %>
  <% if meta.version != "student" %>
  \begin{solution}
    <% if block.explanation %>
    <%= block.explanation|latex_escape %>
    <% endif %>
    <% for step in block.solution_steps|default([]) %>
    \par\textbf{<%= step.title|latex_escape %>}
    <%= step.content|latex_escape %>
    <% endfor %>
  \end{solution}
  <% endif %>
\end{problem}

<% elif block.type == "key_idea" %>
\begin{keyideabox}
  <% if block.title %>\textbf{<%= block.title|latex_escape %>}\par<% endif %>
  <%= block.content|latex_escape %>
\end{keyideabox}

<% elif block.type == "mistake" %>
\begin{mistakebox}
  <% if block.title %>\textbf{<%= block.title|latex_escape %>}\par<% endif %>
  <%= block.content|latex_escape %>
\end{mistakebox}

<% elif block.type == "hint" %>
\begin{hintbox}
  \textbf{提示 <%= block.level|default(1) %>：}<%= block.content|latex_escape %>
\end{hintbox}

<% elif block.type == "route" %>
\begin{routebox}
  \begin{enumerate}
  <% for step in block.steps|default([]) %>
    \item <%= step|latex_escape %>
  <% endfor %>
  \end{enumerate}
\end{routebox}

<% endif %>

<% if meta.version != "student" and block.teaching %>
\begin{teachernote}
  <% if block.teaching.teaching_goal %>
  \textbf{训练目标：}<%= block.teaching.teaching_goal|latex_escape %>\par
  <% endif %>
  <% if block.teaching.expected_blocker %>
  \textbf{预期卡点：}<%= block.teaching.expected_blocker|latex_escape %>\par
  <% endif %>
  <% if block.teaching.mastery_band %>
  \textbf{档位：}<%= block.teaching.mastery_band %>\par
  <% endif %>
  <% if block.teaching.upgrade_rule %>
  \textbf{↑ 升级：}<%= block.teaching.upgrade_rule|latex_escape %>\par
  <% endif %>
  <% if block.teaching.downgrade_rule %>
  \textbf{↓ 降级：}<%= block.teaching.downgrade_rule|latex_escape %>
  <% endif %>
\end{teachernote}
<% endif %>

<% endfor %><# blocks #>
<% endfor %><# sections #>

\end{document}
