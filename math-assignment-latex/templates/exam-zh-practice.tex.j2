<# exam-zh-practice.tex.j2 — 练习页模板 #>
\documentclass{exam-zh}
\usepackage{edu-practice}
<% macro diagram_tikz_body(diagram) -%>
<% if diagram.tikz_code %><%= diagram.tikz_code %><% elif diagram.tikz_path %>\input{\detokenize{<%= diagram.tikz_path|latex_path %>}}<% elif diagram.image_path %>\includegraphics[width=\linewidth]{\detokenize{<%= diagram.image_path|latex_path %>}}<% endif %>
<%- endmacro %>
<% macro render_hints(block) -%>
<% for hint in block.hints|default([]) %>
\begin{hintbox}
  <% if hint.title %>\textbf{<%= hint.title|latex_escape %>：}<% elif hint.level %>\textbf{提示 <%= hint.level|latex_escape %>：}<% else %>\textbf{提示：}<% endif %><% if hint.content_latex %><%= hint.content_latex %><% elif hint.latex %><%= hint.latex %><% else %><%= hint.content|default("")|latex_escape %><% endif %>
\end{hintbox}
<% endfor %>
<%- endmacro %>

<% if meta.version == "student" %>
\examsetup{
  question/show-answer = false,
  fillin/show-answer = false,
  solution/show-solution = hide,
}
<% elif meta.version == "teacher" %>
\examsetup{
  question/show-answer = true,
  fillin/show-answer = true,
  solution/show-solution = show-stay,
}
<% endif %>

% ---------- 教师版解答样式 ----------
\newtcolorbox{solutionblock}{
  enhanced, breakable,
  colback=edu-blue-bg,
  colframe=edu-blue!25,
  boxrule=0pt,
  borderline west={2pt}{0pt}{edu-blue!50},
  arc=0pt,
  left=3mm, right=3mm, top=2mm, bottom=2mm,
  before skip=2mm,
  after skip=3mm,
  fontupper=\small,
}

% 解答步骤编号
\newcounter{solstep}
\newcommand{\solstep}[2]{%
  \stepcounter{solstep}%
  \par\medskip
  \noindent\hangindent=6mm
  {\color{edu-blue}\bfseries\textcircled{\scriptsize\thesolstep}\enspace #1}\enspace #2\par
}

\begin{document}

<% if meta.title %>
\section*{<%= meta.title|latex_escape %>}
<% endif %>

<% for section in sections %>
<% if (section.layout and section.layout.break_before) or section.type == "answer_key" %>
\clearpage
<% endif %>
<% if section.title %>
\section*{<%= section.title|latex_escape %>}
<% endif %>

<% for block in section.blocks %>
<# 解答题：模板层自动保护标题与答题区不被截断 #>
<% if block.type in ("problem", "short_answer") %>
\needspace{8\baselineskip}
<% endif %>

<% if block.type == "choice" %>
<% set diagram_col = block.diagram_col or block.prompt_diagram %>
<% if diagram_col %>
<% set diagram_width = diagram_col.width|default("60mm") %>
\needspace{14\baselineskip}
\begin{question}[points=<%= block.points|default(4) %>]
  \noindent
  \begin{minipage}[t]{\dimexpr\linewidth-<%= diagram_width %>-6mm\relax}
    \vspace{0pt}
    <% if block.stem_latex %>
    <%= block.stem_latex %>
    <% else %>
    <%= block.stem|latex_escape %>
    <% endif %>
    <%= render_hints(block) %>
    \par
    \begin{choices}[columns=1]
    <% for key, text in block.choices|dictsort %>
      \item <%= text|latex_escape %>
    <% endfor %>
    \end{choices}
  \end{minipage}\hfill
  \begin{diagramcoltikz}{<%= diagram_width %>}{<% if diagram_col.caption %><%= diagram_col.caption|latex_escape %><% endif %>}
  <%= diagram_tikz_body(diagram_col) %>
  \end{diagramcoltikz}
  <% if meta.version != "student" and block.answer %>
  \paren[<%= block.answer|latex_escape %>]
  <% if block.explanation %>
  \begin{solutionblock}
    <%= block.explanation %>
  \end{solutionblock}
  <% endif %>
  <% endif %>
\end{question}

<% else %>
\begin{question}[points=<%= block.points|default(4) %>]
  <% if block.stem_latex %>
  <%= block.stem_latex %>
  <% else %>
  <%= block.stem|latex_escape %>
  <% endif %>
  <%= render_hints(block) %>
  \begin{choices}
  <% for key, text in block.choices|dictsort %>
    \item <%= text|latex_escape %>
  <% endfor %>
  \end{choices}
  <% if meta.version != "student" and block.answer %>
  \paren[<%= block.answer|latex_escape %>]
  <% if block.explanation %>
  \begin{solutionblock}
    <%= block.explanation %>
  \end{solutionblock}
  <% endif %>
  <% endif %>
\end{question}
<% endif %>

<% elif block.type == "fillin" %>
<% set fillin_diagram_col = block.diagram_col or block.prompt_diagram %>
<% if fillin_diagram_col %>
<% set fillin_diagram_width = fillin_diagram_col.width|default("60mm") %>
\needspace{12\baselineskip}
\begin{question}[points=<%= block.points|default(4) %>]
  \noindent
  \begin{minipage}[t]{\dimexpr\linewidth-<%= fillin_diagram_width %>-6mm\relax}
    \vspace{0pt}
    <% if block.stem_latex %>
    <%= block.stem_latex %>
    <% else %>
    <%= block.stem|latex_escape %>
    <% endif %>
    <%= render_hints(block) %>
  \end{minipage}\hfill
  \begin{diagramcoltikz}{<%= fillin_diagram_width %>}{<% if fillin_diagram_col.caption %><%= fillin_diagram_col.caption|latex_escape %><% endif %>}
  <%= diagram_tikz_body(fillin_diagram_col) %>
  \end{diagramcoltikz}
  <% if meta.version != "student" and block.answer %>
  \paren[<%= block.answer|latex_escape %>]
  <% if block.explanation %>
  \begin{solutionblock}
    <%= block.explanation %>
  \end{solutionblock}
  <% endif %>
  <% endif %>
\end{question}

<% else %>
\begin{question}[points=<%= block.points|default(4) %>]
  <% if block.stem_latex %>
  <%= block.stem_latex %>
  <% else %>
  <%= block.stem|latex_escape %>
  <% endif %>
  <%= render_hints(block) %>
  <% if meta.version != "student" and block.answer %>
  \paren[<%= block.answer|latex_escape %>]
  <% if block.explanation %>
  \begin{solutionblock}
    <%= block.explanation %>
  \end{solutionblock}
  <% endif %>
  <% endif %>
\end{question}
<% endif %>

<% elif block.type == "diagram_row" %>
<% set diagram_items = block.get("items") or block.get("diagrams") %>
\needspace{<%= block.needspace|default("18\\baselineskip") %>}
\begin{center}
  <% for item in diagram_items|default([]) %>
  \begin{diagramrowtikz}{<%= item.width|default("0.22\\linewidth") %>}{<% if item.label %><%= item.label|latex_escape %><% endif %>}{<% if item.caption %><%= item.caption|latex_escape %><% endif %>}
  <%= diagram_tikz_body(item) %>
  \end{diagramrowtikz}<% if not loop.last %>\hfill<% endif %>
  <% endfor %>
\end{center}

<% elif block.type == "problem" or block.type == "short_answer" %>
\begin{problem}[points=<%= block.points|default(8) %>]
  <% set problem_diagram_col = block.diagram_col or block.prompt_diagram %>
  <% if problem_diagram_col %>
  <% set problem_diagram_width = problem_diagram_col.width|default("60mm") %>
  \noindent
  \begin{minipage}[t]{\dimexpr\linewidth-<%= problem_diagram_width %>-6mm\relax}
    \vspace{0pt}
    <% if block.stem_latex %>
    <%= block.stem_latex %>
    <% else %>
    <%= block.stem|latex_escape %>
    <% endif %>
    <%= render_hints(block) %>
  \end{minipage}\hfill
  \begin{diagramcoltikz}{<%= problem_diagram_width %>}{<% if problem_diagram_col.caption %><%= problem_diagram_col.caption|latex_escape %><% endif %>}
  <%= diagram_tikz_body(problem_diagram_col) %>
  \end{diagramcoltikz}
  \par\medskip
  <% else %>
    <% if block.stem_latex %>
    <%= block.stem_latex %>
    <% else %>
    <%= block.stem|latex_escape %>
    <% endif %>
    <%= render_hints(block) %>
  <% endif %>
  <% if block.answer_space %>
  <% set default_diagram_col = block.answer_space.diagram_col or block.answer_space.diagram %>
  <% if block.answer_space.parts %>
    <% for part in block.answer_space.parts %>
      <% set part_diagram_col = part.diagram_col or part.prompt_diagram or part.diagram or default_diagram_col %>
      <% if part.label %>
  \noindent\textbf{<%= part.label|latex_escape %>}\par
      <% endif %>
      <% if part_diagram_col %>
  \begin{answerareawithdiagramtikz}{<%= part.height|default(block.answer_space.height|default("35mm")) %>}{<%= part_diagram_col.width|default("60mm") %>}{<% if part_diagram_col.caption %><%= part_diagram_col.caption|latex_escape %><% endif %>}
  <%= diagram_tikz_body(part_diagram_col) %>
  \end{answerareawithdiagramtikz}
      <% else %>
  \answerarea[<%= part.height|default(block.answer_space.height|default("35mm")) %>]
      <% endif %>
    <% endfor %>
  <% elif default_diagram_col %>
  \begin{answerareawithdiagramtikz}{<%= block.answer_space.height|default("35mm") %>}{<%= default_diagram_col.width|default("60mm") %>}{<% if default_diagram_col.caption %><%= default_diagram_col.caption|latex_escape %><% endif %>}
  <%= diagram_tikz_body(default_diagram_col) %>
  \end{answerareawithdiagramtikz}
  <% else %>
  \answerarea[<%= block.answer_space.height|default("35mm") %>]
  <% endif %>
  <% endif %>
  <% if meta.version != "student" %>
  \setcounter{solstep}{0}
  \begin{solutionblock}
    <% if block.answer %>
    \textbf{答案：}<%= block.answer %>\par\medskip
    <% endif %>
    <% for step in block.solution_steps|default([]) %>
    \solstep{<%= step.title|latex_escape %>}{<%= step.content %>}
    <% endfor %>
    <% if block.explanation and not block.solution_steps %>
    <%= block.explanation %>
    <% endif %>
  \end{solutionblock}
  <% endif %>
\end{problem}

<% elif block.type == "diagram" %>
\needspace{10\baselineskip}
\begin{center}
  \begin{diagramcoltikz}{<% if block.width %><%= block.width %><% else %>0.82\linewidth<% endif %>}{<% if block.caption %><%= block.caption|latex_escape %><% endif %>}
  <%= diagram_tikz_body(block) %>
  \end{diagramcoltikz}
\end{center}

<% elif block.type == "step" %>
\begin{keyideabox}
  \textbf{<%= block.title|latex_escape %>}
  <%= block.content %>
  <% if block.why %>\par\small <%= block.why|latex_escape %><% endif %>
\end{keyideabox}

<% endif %>

<% endfor %><# blocks #>
<% endfor %><# sections #>

\end{document}
