<# exam-zh-practice.tex.j2 — 练习页模板 #>
<% include "preamble-exam-zh.tex" ignore missing %>

<% if meta.version == "student" %>
\examsetup{
  question/show-answer = false,
  fillin/show-answer = false,
  solution/show-solution = hide,
}
<% elif meta.version == "teacher" %>
\examsetup{
  question/show-answer = true,
  fillin/show-answer = true,
  solution/show-solution = show-stay,
}
<% endif %>

% ---------- 教师版解答样式 ----------
\newtcolorbox{solutionblock}{
  enhanced, breakable,
  colback=edu-blue-bg,
  colframe=edu-blue!25,
  boxrule=0pt,
  borderline west={2pt}{0pt}{edu-blue!50},
  arc=0pt,
  left=3mm, right=3mm, top=2mm, bottom=2mm,
  before skip=2mm,
  after skip=3mm,
  fontupper=\small,
}

% 解答步骤编号
\newcounter{solstep}
\newcommand{\solstep}[2]{%
  \stepcounter{solstep}%
  \par\medskip
  \noindent\hangindent=6mm
  {\color{edu-blue}\bfseries\textcircled{\scriptsize\thesolstep}\enspace #1}\enspace #2\par
}

\begin{document}

<% if meta.title %>
\section*{<%= meta.title|latex_escape %>}
<% endif %>

<% for section in sections %>
<% if (section.layout and section.layout.break_before) or section.type == "answer_key" %>
\clearpage
<% endif %>
<% if section.title %>
\section*{<%= section.title|latex_escape %>}
<% endif %>

<% for block in section.blocks %>
<# 解答题：模板层自动保护标题与答题区不被截断 #>
<% if block.type in ("problem", "short_answer") %>
\needspace{8\baselineskip}
<% endif %>

<% if block.type == "choice" %>
\begin{question}[points=<%= block.points|default(4) %>]
  <% if block.stem_latex %>
  <%= block.stem_latex %>
  <% else %>
  <%= block.stem|latex_escape %>
  <% endif %>
  \begin{choices}
  <% for key, text in block.choices|dictsort %>
    \item <%= text|latex_escape %>
  <% endfor %>
  \end{choices}
  <% if meta.version != "student" and block.answer %>
  \paren[<%= block.answer|latex_escape %>]
  <% if block.explanation %>
  \begin{solutionblock}
    <%= block.explanation %>
  \end{solutionblock}
  <% endif %>
  <% endif %>
\end{question}

<% elif block.type == "fillin" %>
\begin{question}[points=<%= block.points|default(4) %>]
  <% if block.stem_latex %>
  <%= block.stem_latex %>
  <% else %>
  <%= block.stem|latex_escape %>
  <% endif %>
  <% if meta.version != "student" and block.answer %>
  \paren[<%= block.answer|latex_escape %>]
  <% if block.explanation %>
  \begin{solutionblock}
    <%= block.explanation %>
  \end{solutionblock}
  <% endif %>
  <% endif %>
\end{question}

<% elif block.type == "problem" or block.type == "short_answer" %>
\begin{problem}[points=<%= block.points|default(8) %>]
  <% if block.stem_latex %>
  <%= block.stem_latex %>
  <% else %>
  <%= block.stem|latex_escape %>
  <% endif %>
  <% if block.answer_space %>
  \answerarea[<%= block.answer_space.height|default("35mm") %>]
  <% endif %>
  <% if meta.version != "student" %>
  \setcounter{solstep}{0}
  \begin{solutionblock}
    <% if block.answer %>
    \textbf{答案：}<%= block.answer %>\par\medskip
    <% endif %>
    <% for step in block.solution_steps|default([]) %>
    \solstep{<%= step.title|latex_escape %>}{<%= step.content %>}
    <% endfor %>
    <% if block.explanation and not block.solution_steps %>
    <%= block.explanation %>
    <% endif %>
  \end{solutionblock}
  <% endif %>
\end{problem}

<% elif block.type == "step" %>
\begin{keyideabox}
  \textbf{<%= block.title|latex_escape %>}
  <%= block.content %>
  <% if block.why %>\par\small <%= block.why|latex_escape %><% endif %>
\end{keyideabox}

<% endif %>

<% endfor %><# blocks #>
<% endfor %><# sections #>

\end{document}
