#!/usr/bin/env bash
set -euo pipefail

outdir="."
tex=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --outdir)
      outdir="$2"
      shift 2
      ;;
    --keep-logs)
      shift
      ;;
    *)
      tex="$1"
      shift
      ;;
  esac
done

if [[ -z "$tex" ]]; then
  echo "missing tex input" >&2
  exit 2
fi

mkdir -p "$outdir"
exec /opt/homebrew/bin/xelatex -interaction=nonstopmode -halt-on-error -output-directory="$outdir" "$tex"
